# Copy this file to core/.env and fill in real values.
OPENAI_API_KEY=your_openai_api_key_here

# Optional base URL for compatible gateways/proxies.
OPENAI_BASE_URL=

# Planner agent behavior:
# true  -> use LLM planner (default behavior)
# false -> force deterministic Python fallback planner
PLANNER_AGENT=true

# Optional override. Defaults to schema model registry value (models.PLANNER).
PLANNER_MODEL=gpt-4o-mini
