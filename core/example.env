# Copy this file to core/.env and fill in real values.
OPENAI_API_KEY=your_openai_api_key_here

# Optional base URL for compatible gateways/proxies.
OPENAI_BASE_URL=

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

RAG_HISTORY_WINDOW=10
RAG_SESSION_TTL_SECONDS=900

PLANNER_AGENT=true

PLANNER_MODEL=gpt-4o-mini
PLANNER_PRESERVE_RICH_QUERY=false

RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_K=20
RERANK_MIN_TOP_SCORE=0.7

EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Rate limiting (dual-window, tracked by client IP)
RATE_LIMIT_SHORT_WINDOW_SECONDS=60
RATE_LIMIT_SHORT_MAX_REQUESTS=5
RATE_LIMIT_LONG_WINDOW_SECONDS=86400
RATE_LIMIT_LONG_MAX_REQUESTS=30

# Vector store provider: "redis_stack" (local) or "upstash" (serverless)
VECTOR_STORE_PROVIDER=redis_stack

# Upstash Redis URL (rediss://...) — only needed when VECTOR_STORE_PROVIDER=upstash
# The same URL is used for KV operations (rate limiter, chat history).
UPSTASH_REDIS_URL=

# Upstash Vector endpoint + token — only needed when VECTOR_STORE_PROVIDER=upstash
UPSTASH_VECTOR_URL=
UPSTASH_VECTOR_TOKEN=
